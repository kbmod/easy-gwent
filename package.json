{
  "name": "easy-gwent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @gwent/client",
    "dev:server": "npm run dev -w @gwent/server",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @gwent/server",
    "test": "vitest run",
    "fetch-assets": "node --experimental-strip-types scripts/fetch-assets.ts"
  },
  "devDependencies": {
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
